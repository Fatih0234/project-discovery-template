# GitHub token for API access (required for search; unauthenticated rate limits are very low)
# Use GITHUB_TOKEN locally; in Codespaces use GH_TOKEN (GitHub blocks the GITHUB_ prefix in secrets)
GITHUB_TOKEN=ghp_your_token_here
# GH_TOKEN=ghp_your_token_here  # use this name in Codespaces secrets

# LLM keys — at least one needed for AI-powered summaries; both optional (template fallback used otherwise)
OPENAI_API_KEY=sk-your_openai_key_here
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key_here
